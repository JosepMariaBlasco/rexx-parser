  flat = self~highlight(.Array~of('a.2d.bar.3 = 1'), options.)
  self~assertTrue(flat~caselessPos('rx-stem') > 0, -
    "HTML compound: stem name has rx-stem class")

::Method test_html_compound_stem_dot
  options. = self~htmlOptions
  flat = self~highlight(.Array~of('a.2d.bar.3 = 1'), options.)
  self~assertTrue(flat~pos('>a.</span>') > 0, -
    "HTML compound: stem includes its dot")

::Method test_html_compound_constant
  options. = self~htmlOptions
  flat = self~highlight(.Array~of('a.2d.bar.3 = 1'), options.)
  self~assertTrue(flat~caselessPos('rx-lit') > 0, -
    "HTML compound: constant symbol (2d) has rx-lit class")

::Method test_html_compound_variable
  options. = self~htmlOptions
  flat = self~highlight(.Array~of('a.2d.bar.3 = 1'), options.)
  self~assertTrue(flat~caselessPos('rx-var') > 0, -
    "HTML compound: variable tail (bar) has rx-var class")

::Method test_html_compound_number
  options. = self~htmlOptions
  flat = self~highlight(.Array~of('a.2d.bar.3 = 1'), options.)
  self~assertTrue(flat~caselessPos('rx-int') > 0, -
    "HTML compound: numeric tail (3) has rx-int class")

::Method test_html_compound_separator
  options. = self~htmlOptions
  flat = self~highlight(.Array~of('a.2d.bar.3 = 1'), options.)
  self~assertTrue(flat~caselessPos('rx-spe') > 0, -
    "HTML compound: tail dot separators have rx-spe class")

/******************************************************************************/
/* HTML element categories: symbols                                           */
/******************************************************************************/

::Method test_cat_keyword
  options. = self~htmlOptions
  source = .Array~of( -
    'Do i = 1 To 10 By 2', -
    '  Nop', -
    'End', -
    '::Class Foo SubClass Bar Public' -
  )
  flat = self~highlight(source, options.)
  self~assertTrue(flat~caselessPos('rx-kw') > 0, -
    "Categories: keyword (Do) has rx-kw")

::Method test_cat_subkeyword
  options. = self~htmlOptions
  source = .Array~of( -
    'Do i = 1 To 10 By 2', -
    '  Nop', -
    'End', -
    '::Class Foo SubClass Bar Public' -
  )
  flat = self~highlight(source, options.)
  self~assertTrue(flat~caselessPos('rx-skw') > 0, -
    "Categories: subkeyword (To, By) has rx-skw")

::Method test_cat_directive
  options. = self~htmlOptions
  source = .Array~of( -
    'Do i = 1 To 10 By 2', -
    '  Nop', -
    'End', -
    '::Class Foo SubClass Bar Public' -
  )
  flat = self~highlight(source, options.)
  self~assertTrue(flat~caselessPos('rx-dir') > 0, -
    "Categories: directive start (::) has rx-dir")

::Method test_cat_directive_keyword
  options. = self~htmlOptions
  source = .Array~of( -
    'Do i = 1 To 10 By 2', -
    '  Nop', -
    'End', -
    '::Class Foo SubClass Bar Public' -
  )
  flat = self~highlight(source, options.)
  self~assertTrue(flat~caselessPos('rx-dkw') > 0, -
    "Categories: directive keyword (Class) has rx-dkw")

::Method test_cat_directive_subkeyword
  options. = self~htmlOptions
  source = .Array~of( -
    'Do i = 1 To 10 By 2', -
    '  Nop', -
    'End', -
    '::Class Foo SubClass Bar Public' -
  )
  flat = self~highlight(source, options.)
  self~assertTrue(flat~caselessPos('rx-dskw') > 0, -
    "Categories: directive subkeyword (SubClass, Public) has rx-dskw")

/******************************************************************************/
/* HTML element categories: variable types                                    */
