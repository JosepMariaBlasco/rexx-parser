  flat = self~highlight(.Array~of('/* line 1', '   line 2 */'), options.)
  self~assertTrue(flat~pos('line 2') > 0, -
    "HTML multi-line comment: second line is present")

/******************************************************************************/
/* HTML: compound variable highlighting                                       */
/******************************************************************************/

::Method test_html_compound_stem
