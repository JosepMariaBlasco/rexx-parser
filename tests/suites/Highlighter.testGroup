  source = .Array~of( -
    'x = 1', -
    '::Class Foo', -
    '::Method bar', -
    '  Expose name', -
    '  Say name' -
  )
  flat = self~highlight(source, options.)
  self~assertTrue(flat~caselessPos('rx-var') > 0, -
    "Categories: simple variable (x) has rx-var")

::Method test_cat_exposed_variable
