#!/usr/bin/env rexx
/******************************************************************************/
/*                                                                            */
/* Highlighter.testGroup - Tests for Highlighter.cls, ANSI driver, StylePatch */
/* =======================================================================    */
/*                                                                            */
/* This program is part of the Rexx Parser package                            */
/* [See https://rexx.epbcn.com/rexx-parser/]                                  */
/*                                                                            */
/* Copyright (c) 2024-2026 Josep Maria Blasco <josep.maria.blasco@epbcn.com>  */
/*                                                                            */
/* License: Apache License 2.0 (https://www.apache.org/licenses/LICENSE-2.0)  */
/*                                                                            */
/* Version history:                                                           */
/*                                                                            */
/* Date     Version Details                                                   */
/* -------- ------- --------------------------------------------------------- */
/* 20260316    0.5  First version                                             */
/*                                                                            */
/******************************************************************************/

parse source . . fileSpec
group = .TestGroup~new(fileSpec)
group~add(.Highlighter.testGroup)
If group~isAutomatedTest Then
  Return group
Else
  Return group~suite~execute~~print

::Requires "ooTest.frm"
::Requires "Highlighter.cls"
::Requires "StylePatch.cls"

::Class Highlighter.testGroup Subclass ooTestCase Public

/******************************************************************************/
/* Helper methods                                                             */
/******************************************************************************/

::Method htmlOptions Private
  options. = 0
  options.mode = "HTML"
  options.style = "dark"
  Return options.

::Method ansiOptions Private
  options. = 0
  options.mode = "ANSI"
  options.style = "dark"
  Return options.

::Method highlight Private
  Use Arg source, options., patch = .nil
  hl = .Highlighter~new("test", source, options.)
  If patch == .nil Then
    result = hl~parse
  Else
    result = hl~parse(patch)
  Return result~makeString('L', "0A"x)

/******************************************************************************/
/* HTML: basic highlighting                                                   */
/******************************************************************************/

::Method test_html_basic_returns_array
  options. = self~htmlOptions
  source = .Array~of('Say "Hello"')
  hl = .Highlighter~new("test", source, options.)
  result = hl~parse
  self~assertTrue(result~isA(.Array), -
    "HTML basic: returns an array")

::Method test_html_basic_highlight_div
  options. = self~htmlOptions
  flat = self~highlight(.Array~of('Say "Hello"'), options.)
  self~assertTrue(flat~caselessPos('highlight-rexx-dark') > 0, -
    "HTML basic: contains highlight div with dark style")

::Method test_html_basic_pre_code
  options. = self~htmlOptions
  flat = self~highlight(.Array~of('Say "Hello"'), options.)
  self~assertTrue(flat~caselessPos('<pre><code') > 0, -
    "HTML basic: contains pre/code tags")

::Method test_html_basic_keyword
  options. = self~htmlOptions
  flat = self~highlight(.Array~of('Say "Hello"'), options.)
  self~assertTrue(flat~caselessPos('rx-kw') > 0, -
    "HTML basic: Say is highlighted as keyword")

::Method test_html_basic_string
  options. = self~htmlOptions
  flat = self~highlight(.Array~of('Say "Hello"'), options.)
  self~assertTrue(flat~caselessPos('rx-str') > 0, -
    "HTML basic: string is highlighted")

/******************************************************************************/
/* HTML: light style                                                          */
/******************************************************************************/

::Method test_html_light_style
  options. = self~htmlOptions
  options.style = "light"
  flat = self~highlight(.Array~of('Nop'), options.)
  self~assertTrue(flat~caselessPos('highlight-rexx-light') > 0, -
    "HTML light: contains highlight div with light style")

::Method test_html_light_no_dark
  options. = self~htmlOptions
  options.style = "light"
  flat = self~highlight(.Array~of('Nop'), options.)
  self~assertTrue(flat~caselessPos('highlight-rexx-dark') == 0, -
    "HTML light: does not contain dark style")

/******************************************************************************/
/* HTML: custom classprefix                                                   */
/******************************************************************************/

::Method test_html_classprefix_applied
  options. = self~htmlOptions
  options.classprefix = "my-"
  flat = self~highlight(.Array~of('Say "Hello"'), options.)
  self~assertTrue(flat~caselessPos('my-kw') > 0, -
    "HTML classprefix: custom prefix applied to keyword")

::Method test_html_classprefix_no_default
  options. = self~htmlOptions
  options.classprefix = "my-"
  flat = self~highlight(.Array~of('Say "Hello"'), options.)
  self~assertTrue(flat~caselessPos('rx-kw') == 0, -
    "HTML classprefix: default prefix not present")

/******************************************************************************/
/* HTML: operator group vs full                                               */
/******************************************************************************/

::Method test_html_operator_group_has_rxop
  options. = self~htmlOptions
  options.operator = "group"
  flat = self~highlight(.Array~of('x = 1 + 2'), options.)
  self~assertTrue(flat~caselessPos('rx-op') > 0, -
    "HTML operator=group: contains rx-op")

::Method test_html_operator_group_no_rxadd
  options. = self~htmlOptions
  options.operator = "group"
  flat = self~highlight(.Array~of('x = 1 + 2'), options.)
  self~assertTrue(flat~caselessPos('rx-add') == 0, -
    "HTML operator=group: does not contain rx-add")

::Method test_html_operator_full_has_rxop
  options. = self~htmlOptions
  options.operator = "full"
  flat = self~highlight(.Array~of('x = 1 + 2'), options.)
  self~assertTrue(flat~caselessPos('rx-op') > 0, -
    "HTML operator=full: contains generic rx-op")

::Method test_html_operator_full_has_rxadd
  options. = self~htmlOptions
  options.operator = "full"
  flat = self~highlight(.Array~of('x = 1 + 2'), options.)
  self~assertTrue(flat~caselessPos('rx-add') > 0, -
    "HTML operator=full: contains detailed rx-add")

/******************************************************************************/
/* HTML: constant group vs full                                               */
/******************************************************************************/

::Method test_html_constant_group_has_rxconst
  options. = self~htmlOptions
  options.constant = "group"
  flat = self~highlight(.Array~of('Call Exit'), options.)
  self~assertTrue(flat~caselessPos('rx-const') > 0, -
    "HTML constant=group: contains rx-const")

::Method test_html_constant_group_no_detail
  options. = self~htmlOptions
  options.constant = "group"
  flat = self~highlight(.Array~of('Call Exit'), options.)
  self~assertTrue(flat~caselessPos('rx-ext-proc') == 0, -
    "HTML constant=group: does not contain detailed class")

::Method test_html_constant_full_has_rxconst
  options. = self~htmlOptions
  options.constant = "full"
  flat = self~highlight(.Array~of('Call Exit'), options.)
  self~assertTrue(flat~caselessPos('rx-const') > 0, -
    "HTML constant=full: contains generic rx-const")

::Method test_html_constant_full_has_detail
  options. = self~htmlOptions
  options.constant = "full"
  flat = self~highlight(.Array~of('Call Exit'), options.)
  self~assertTrue(flat~caselessPos('rx-ext-proc') > 0, -
    "HTML constant=full: contains detailed rx-ext-proc")

/******************************************************************************/
/* HTML: numberLines + startFrom                                              */
/******************************************************************************/

::Method test_html_numberlines_class
  options. = self~htmlOptions
  options.numberLines = .True
  options.startFrom = 10
  flat = self~highlight(.Array~of('Say 1', 'Say 2', 'Say 3'), options.)
  self~assertTrue(flat~caselessPos('number-lines') > 0, -
    "HTML numberLines: pre has number-lines class")

::Method test_html_startfrom_first
  options. = self~htmlOptions
  options.numberLines = .True
  options.startFrom = 10
  flat = self~highlight(.Array~of('Say 1', 'Say 2', 'Say 3'), options.)
  self~assertTrue(flat~caselessPos('lineNo="10"') > 0, -
    "HTML startFrom: first line number is 10")

::Method test_html_startfrom_third
  options. = self~htmlOptions
  options.numberLines = .True
  options.startFrom = 10
  flat = self~highlight(.Array~of('Say 1', 'Say 2', 'Say 3'), options.)
  self~assertTrue(flat~caselessPos('lineno="12"') > 0, -
    "HTML startFrom: third line number is 12")

/******************************************************************************/
/* HTML: docComments detailed vs block                                        */
/******************************************************************************/

::Method test_html_doccomments_detailed_armature
