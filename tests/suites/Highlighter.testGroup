    'x = 1', -
    '::Class Foo', -
    '::Method bar', -
    '  Expose name', -
    '  Say name' -
  )
  flat = self~highlight(source, options.)
  self~assertTrue(flat~caselessPos('rx-xvar') > 0, -
    "Categories: exposed variable (name after Expose) has rx-xvar")

