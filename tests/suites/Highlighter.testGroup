/******************************************************************************/
/* HTML element categories: specials with full detail                         */
/******************************************************************************/

::Method test_cat_paren_full
  options. = self~htmlOptions
  options.special = "full"
  flat = self~highlight(.Array~of('Call foo(1, 2)'), options.)
  self~assertTrue(flat~caselessPos('rx-spe rx-paren') > 0, -
    "Categories: parentheses have rx-spe rx-paren (full)")

::Method test_cat_comma_full
  options. = self~htmlOptions
  options.special = "full"
