  options.docComments = "detailed"
  flat = self~highlight(.Array~of('---', '--- A doc comment', '---'), options.)
  self~assertTrue(flat~caselessPos('rx-doc-comment-armature') > 0, -
    "HTML docComments=detailed: contains armature sub-element")

::Method test_html_doccomments_detailed_summary
  options. = self~htmlOptions
  options.docComments = "detailed"
  flat = self~highlight(.Array~of('---', '--- A doc comment', '---'), options.)
  self~assertTrue(flat~caselessPos('rx-doc-comment-summary') > 0, -
    "HTML docComments=detailed: contains summary sub-element")

::Method test_html_doccomments_block_class
  options. = self~htmlOptions
  options.docComments = "block"
  flat = self~highlight(.Array~of('---', '--- A doc comment', '---'), options.)
  self~assertTrue(flat~caselessPos('rx-doc-comment-markdown') > 0, -
    "HTML docComments=block: contains doc-comment class")

::Method test_html_doccomments_block_no_armature
  options. = self~htmlOptions
  options.docComments = "block"
  flat = self~highlight(.Array~of('---', '--- A doc comment', '---'), options.)
  self~assertTrue(flat~caselessPos('rx-doc-comment-armature') == 0, -
    "HTML docComments=block: no armature sub-element")

/******************************************************************************/
/* HTML: multi-line comment                                                   */
/******************************************************************************/

::Method test_html_multiline_comment_class
  options. = self~htmlOptions
  flat = self~highlight(.Array~of('/* line 1', '   line 2 */'), options.)
  self~assertTrue(flat~caselessPos('rx-cm') > 0, -
    "HTML multi-line comment: contains comment class")

::Method test_html_multiline_comment_content
