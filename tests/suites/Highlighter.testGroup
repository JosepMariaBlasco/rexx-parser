    "Categories: line comment has rx-lncm")

::Method test_cat_doc_comment
  options. = self~htmlOptions
  flat = self~highlight(.Array~of('/* block */', '-- line comment', '--- doc comment'), options.)
  self~assertTrue(flat~caselessPos('rx-doc-comment') > 0, -
    "Categories: doc-comment has rx-doc-comment")

