/******************************************************************************/
/* HTML element categories: taken constants (function/class/method names)     */
/******************************************************************************/

::Method test_cat_class_name_full
  options. = self~htmlOptions
  options.constant = "full"
  source = .Array~of( -
    '::Class Foo', -
    '::Method bar', -
