/******************************************************************************/
/* HTML: options.additional as string patch                                   */
/******************************************************************************/

::Method test_html_additional_bold
  options. = self~htmlOptions
  options.additional = "Element keyword bold red"
  flat = self~highlight(.Array~of('Say "Hello"'), options.)
  self~assertTrue(flat~caselessPos('font-weight:bold') > 0, -
    "HTML additional: bold applied via options.additional")

::Method test_html_additional_red
  options. = self~htmlOptions
  options.additional = "Element keyword bold red"
  flat = self~highlight(.Array~of('Say "Hello"'), options.)
  self~assertTrue(flat~caselessPos('#ff0000') > 0, -
    "HTML additional: red color applied via options.additional")

/******************************************************************************/
/* HTML: Syntax error in source is propagated                                 */
/******************************************************************************/

::Method test_html_syntax_error
  options. = self~htmlOptions
  self~expectSyntax(36.901)
  hl = .Highlighter~new("test", .Array~of('Say (('), options.)
  hl~parse

/******************************************************************************/
/* ANSI: basic output                                                         */
/******************************************************************************/

::Method test_ansi_basic_has_esc
  options. = self~ansiOptions
  flat = self~highlight(.Array~of('Say "Hello"'), options.)
  self~assertTrue(flat~pos("1B"x) > 0, -
    "ANSI basic: output contains ESC sequences")

::Method test_ansi_basic_has_sgr_reset
  options. = self~ansiOptions
  flat = self~highlight(.Array~of('Say "Hello"'), options.)
  self~assertTrue(flat~pos("1B"x"[0m") > 0, -
    "ANSI basic: output contains SGR reset")

::Method test_ansi_basic_no_div
  options. = self~ansiOptions
  flat = self~highlight(.Array~of('Say "Hello"'), options.)
  self~assertTrue(flat~caselessPos('<div') == 0, -
    "ANSI basic: no HTML div tags")

::Method test_ansi_basic_no_span
  options. = self~ansiOptions
  flat = self~highlight(.Array~of('Say "Hello"'), options.)
  self~assertTrue(flat~caselessPos('<span') == 0, -
    "ANSI basic: no HTML span tags")

/******************************************************************************/
/* ANSI: numberLines                                                          */
/******************************************************************************/

::Method test_ansi_numberlines
  options. = self~ansiOptions
  options.numberLines = .True
  flat = self~highlight(.Array~of('Say 1', 'Say 2'), options.)
  self~assertTrue(flat~pos(' | ') > 0, -
    "ANSI numberLines: contains line number separator")

/******************************************************************************/
/* ANSI: width padding                                                        */
/******************************************************************************/

::Method test_ansi_width_has_esc
  options. = self~ansiOptions
  options.width = 40
  flat = self~highlight(.Array~of('Nop'), options.)
  self~assertTrue(flat~pos("1B"x) > 0, -
    "ANSI width: padded output contains ESC sequences")

::Method test_ansi_width_wider
  options. = self~ansiOptions
  options.width = 40
  flat = self~highlight(.Array~of('Nop'), options.)
  self~assertTrue(flat~length > 40, -
    "ANSI width=40: output is wider than source alone")

/******************************************************************************/
/* ANSI: StylePatch changes SGR output                                        */
/******************************************************************************/

::Method test_ansi_patch_differs
  options. = self~ansiOptions
  source = .Array~of('Say "Hello"')
  plain = self~highlight(source, options.)
  patch = .StylePatch~of("All Strings bold red")
  patched = self~highlight(source, options., patch)
  self~assertTrue(plain \== patched, -
    "ANSI patch: patched output differs from unpatched")

::Method test_ansi_patch_red_sgr
  options. = self~ansiOptions
  patch = .StylePatch~of("All Strings bold red")
  patched = self~highlight(.Array~of('Say "Hello"'), options., patch)
  self~assertTrue(patched~pos('38;2;255;0;0;') > 0, -
    "ANSI patch: red color appears as SGR 38;2;255;0;0")

/******************************************************************************/
/* StylePatch: from string                                                    */
/******************************************************************************/

::Method test_stylepatch_string_bold
  options. = self~htmlOptions
  patch = .StylePatch~of("All Strings bold red")
  flat = self~highlight(.Array~of('Say "Hello"'), options., patch)
  self~assertTrue(flat~caselessPos('font-weight:bold') > 0, -
    "StylePatch string: bold applied")

::Method test_stylepatch_string_red
  options. = self~htmlOptions
  patch = .StylePatch~of("All Strings bold red")
  flat = self~highlight(.Array~of('Say "Hello"'), options., patch)
  self~assertTrue(flat~caselessPos('#ff0000') > 0, -
    "StylePatch string: red color applied")

/******************************************************************************/
/* StylePatch: from array                                                     */
/******************************************************************************/

::Method test_stylepatch_array_red
  options. = self~htmlOptions
  patch = .StylePatch~of(.Array~of("All Strings bold red", "Element keyword italic"))
  flat = self~highlight(.Array~of('Say "Hello"'), options., patch)
  self~assertTrue(flat~caselessPos('#ff0000') > 0, -
    "StylePatch array: red color from first spec")

::Method test_stylepatch_array_italic
  options. = self~htmlOptions
  patch = .StylePatch~of(.Array~of("All Strings bold red", "Element keyword italic"))
  flat = self~highlight(.Array~of('Say "Hello"'), options., patch)
  self~assertTrue(flat~caselessPos('font-style:italic') > 0, -
    "StylePatch array: italic from second spec")

/******************************************************************************/
/* StylePatch: Element mode                                                   */
/******************************************************************************/

::Method test_stylepatch_element_underline
  options. = self~htmlOptions
  patch = .StylePatch~of("Element keyword underline green")
  flat = self~highlight(.Array~of('Say "Hello"'), options., patch)
  self~assertTrue(flat~caselessPos('text-decoration:underline') > 0, -
    "StylePatch Element: underline applied to keyword")

::Method test_stylepatch_element_green
  options. = self~htmlOptions
  patch = .StylePatch~of("Element keyword underline green")
  flat = self~highlight(.Array~of('Say "Hello"'), options., patch)
  self~assertTrue(flat~caselessPos('#008000') > 0, -
    "StylePatch Element: green color applied")

/******************************************************************************/
/* StylePatch: Name mode                                                      */
/******************************************************************************/

::Method test_stylepatch_name_bold
  options. = self~htmlOptions
  source = .Array~of('Call MyProc', '', 'MyProc:', '  Return')
  patch = .StylePatch~of("Name INTERNAL.SUBROUTINE bold green")
  flat = self~highlight(source, options., patch)
  self~assertTrue(flat~caselessPos('font-weight:bold') > 0, -
    "StylePatch Name: bold applied to named constant")

::Method test_stylepatch_name_green
  options. = self~htmlOptions
  source = .Array~of('Call MyProc', '', 'MyProc:', '  Return')
  patch = .StylePatch~of("Name INTERNAL.SUBROUTINE bold green")
  flat = self~highlight(source, options., patch)
  self~assertTrue(flat~caselessPos('#008000') > 0, -
    "StylePatch Name: green color applied to named constant")

/******************************************************************************/
/* StylePatch: bold, italic, underline, no bold                               */
/******************************************************************************/

::Method test_stylepatch_attrs_bold
  options. = self~htmlOptions
  patch = .StylePatch~of("Element keyword bold italic underline red")
  flat = self~highlight(.Array~of('Say "Hello"'), options., patch)
  self~assertTrue(flat~caselessPos('font-weight:bold') > 0, -
    "StylePatch attrs: bold applied")

::Method test_stylepatch_attrs_italic
  options. = self~htmlOptions
  patch = .StylePatch~of("Element keyword bold italic underline red")
  flat = self~highlight(.Array~of('Say "Hello"'), options., patch)
  self~assertTrue(flat~caselessPos('font-style:italic') > 0, -
    "StylePatch attrs: italic applied")

::Method test_stylepatch_attrs_underline
  options. = self~htmlOptions
  patch = .StylePatch~of("Element keyword bold italic underline red")
  flat = self~highlight(.Array~of('Say "Hello"'), options., patch)
  self~assertTrue(flat~caselessPos('text-decoration:underline') > 0, -
    "StylePatch attrs: underline applied")

::Method test_stylepatch_attrs_no_bold
  options. = self~htmlOptions
  patch = .StylePatch~of("Element keyword no bold")
  flat = self~highlight(.Array~of('Say "Hello"'), options., patch)
  self~assertTrue(flat~caselessPos('font-weight:normal') > 0, -
    "StylePatch attrs: 'no bold' produces font-weight:normal")

/******************************************************************************/
/* StylePatch: hex colors #rrggbb and #rgb                                    */
/******************************************************************************/

::Method test_stylepatch_hex_rrggbb
  options. = self~htmlOptions
  patch = .StylePatch~of("Element keyword #ff8800")
  flat = self~highlight(.Array~of('Say "Hello"'), options., patch)
  self~assertTrue(flat~caselessPos('ff8800') > 0, -
    "StylePatch #rrggbb: hex color applied")

::Method test_stylepatch_hex_rgb_expanded
  options. = self~htmlOptions
  patch = .StylePatch~of("Element keyword #f80")
  flat = self~highlight(.Array~of('Say "Hello"'), options., patch)
  self~assertTrue(flat~caselessPos('ff8800') > 0, -
    "StylePatch #rgb: shorthand expanded to rrggbb")

/******************************************************************************/
/* StylePatch: foreground:background                                          */
/******************************************************************************/

::Method test_stylepatch_fgbg_foreground
  options. = self~htmlOptions
  patch = .StylePatch~of("Element keyword red:blue")
  flat = self~highlight(.Array~of('Say "Hello"'), options., patch)
  self~assertTrue(flat~caselessPos('#ff0000') > 0, -
    "StylePatch fg:bg: foreground red applied")

::Method test_stylepatch_fgbg_bgpresent
  options. = self~htmlOptions
  patch = .StylePatch~of("Element keyword red:blue")
  flat = self~highlight(.Array~of('Say "Hello"'), options., patch)
  self~assertTrue(flat~caselessPos('background-color') > 0, -
    "StylePatch fg:bg: background-color present")

::Method test_stylepatch_fgbg_background
  options. = self~htmlOptions
  patch = .StylePatch~of("Element keyword red:blue")
  flat = self~highlight(.Array~of('Say "Hello"'), options., patch)
  self~assertTrue(flat~caselessPos('#0000ff') > 0, -
    "StylePatch fg:bg: background blue applied")

/******************************************************************************/
/* StylePatch: semicolon-separated specs in a single string                   */
/******************************************************************************/

::Method test_stylepatch_semicolon_first
  options. = self~htmlOptions
  patch = .StylePatch~of("All Strings red; Element keyword italic")
  flat = self~highlight(.Array~of('Say "Hello"'), options., patch)
  self~assertTrue(flat~caselessPos('#ff0000') > 0, -
    "StylePatch semicolon: first spec (red strings) applied")

::Method test_stylepatch_semicolon_second
  options. = self~htmlOptions
  patch = .StylePatch~of("All Strings red; Element keyword italic")
  flat = self~highlight(.Array~of('Say "Hello"'), options., patch)
  self~assertTrue(flat~caselessPos('font-style:italic') > 0, -
    "StylePatch semicolon: second spec (italic keyword) applied")

/******************************************************************************/
/* StylePatch: comment lines (--) are skipped                                 */
/******************************************************************************/

::Method test_stylepatch_comments_skipped
  options. = self~htmlOptions
  patch = .StylePatch~of(.Array~of("-- This is a comment", "All Strings red"))
  flat = self~highlight(.Array~of('Say "Hello"'), options., patch)
  self~assertTrue(flat~caselessPos('#ff0000') > 0, -
    "StylePatch comments: comment line skipped, red applied")

/******************************************************************************/
/* StylePatch errors                                                          */
/******************************************************************************/

::Method test_stylepatch_error_bad_mode
  self~expectSyntax(88.900)
  .StylePatch~of("Bogus Strings red")

::Method test_stylepatch_error_bad_class
  self~expectSyntax(88.900)
  .StylePatch~of("Element boguscat red")

::Method test_stylepatch_error_bad_fg_color
  self~expectSyntax(93.900)
  .StylePatch~of("Element keyword notacolor")

::Method test_stylepatch_error_bad_bg_color
  self~expectSyntax(93.900)
  .StylePatch~of("Element keyword red:notacolor")

::Method test_stylepatch_error_bad_hex
  self~expectSyntax(93.900)
  .StylePatch~of("Element keyword #zzzzzz")

::Method test_stylepatch_error_bad_name
  self~expectSyntax(88.900)
  .StylePatch~of("Name NONEXISTENT.THING bold")

::Method test_stylepatch_error_trailing_no
  self~expectSyntax(93.900)
  .StylePatch~of("Element keyword no")