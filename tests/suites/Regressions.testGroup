#!/usr/bin/env rexx
/******************************************************************************/
/*                                                                            */
/* Regressions.testGroup - Regression tests (code that must parse correctly)  */
/* =====================================================================      */
/*                                                                            */
/* This program is part of the Rexx Parser package                            */
/* [See https://rexx.epbcn.com/rexx-parser/]                                  */
/*                                                                            */
/* Copyright (c) 2024-2026 Josep Maria Blasco <josep.maria.blasco@epbcn.com>  */
/*                                                                            */
/* License: Apache License 2.0 (https://www.apache.org/licenses/LICENSE-2.0)  */
/*                                                                            */
/* Version history:                                                           */
/*                                                                            */
/* Date     Version Details                                                   */
/* -------- ------- --------------------------------------------------------- */
/* 20260317    0.5  Migrated from shouldwork.rex to ooRexxUnit                */
/*                                                                            */
/******************************************************************************/

parse source . . fileSpec
group = .TestGroup~new(fileSpec)
group~add(.Regressions.testGroup)
If group~isAutomatedTest Then
  Return group
Else
  Return group~suite~execute~~print

::Requires "ooTest.frm"
::Requires "ParserTestCase.cls"

::Class Regressions.testGroup Subclass ParserTestCase Public

/******************************************************************************/
/* .o is a bad target, but .o~m is not.                                       */
/* Reported by JLF. Fixed on 20250419.                                        */
/******************************************************************************/

::Method test_use_arg_environment_message
  self~parserOK("Use Arg .o~m")

/******************************************************************************/
/* Nested expression lists should reset their terminators.                    */
/* Reported by JLF. Fixed on 20250419.                                        */
/******************************************************************************/

::Method test_nested_expression_list_terminators
  self~parserOK("x = (+10)")

/******************************************************************************/
/* Attribute bodies are tricky (Expose after ::Attribute ... Set).            */
/* Reported by JLF. Fixed on 20250419.                                        */
/******************************************************************************/

::Method test_attribute_body_expose
  self~parserOK(( -
    "::Class TestClass",          -
    "::Attribute Attr Class Set", -
    "  Expose v1 v2 v3",          -
    "",                            -
    "::Routine R"                  -
  ))

/******************************************************************************/
/* Control variable accepted in LEAVE and ITERATE.                            */
/* Reported by JLF. Fixed on 20250419.                                        */
/* Uses parserOnly: the code references uninitialized variables (n,           */
/* condition) so the interpreter would raise runtime errors.                  */
/******************************************************************************/

::Method test_leave_iterate_control_variable
  -- Simple loop with control variable
  self~parserOnly(( -
    "Do i = 1 To n",            -
    "  If condition Then Leave   i",    -
    "  If condition Then Iterate i",    -
    "End"                        -
  ))
  -- Labeled loop with separate control variable
  self~parserOnly(( -
    "Do Label i j = 1 To n",    -
    "  If condition Then Leave   i",    -
    "  If condition Then Iterate i",    -
    "End"                        -
  ))

/******************************************************************************/
/* Spurious check for control variables in SELECT blocks.                     */
/* LEAVE/ITERATE targeting an outer loop from inside a SELECT.                */
/* Reported by JLF. Fixed on 20250419.                                        */
/* Uses parserOnly: infinite loop (Do ... i = 1 By 1 with no exit).          */
/******************************************************************************/

::Method test_leave_iterate_through_select
  self~parserOnly(( -
    "Do Label out i = 1 By 1",   -
    "  Select",                   -
    "    When 1 Then Leave   Out",-
    "    When 1 Then Iterate Out",-
    "  End",                      -
    "End"                         -
  ))

/******************************************************************************/
/* SIGNAL to an existing label works.                                         */
/* Reported by JLF. Fixed on 20250419.                                        */
/******************************************************************************/

::Method test_signal_existing_label
  self~parserOK(( -
    "Signal ExistingLabel",       -
    "ExistingLabel: Nop"          -
  ))

/******************************************************************************/
/* Different expressions correctly checked inside BIFs.                       */
/* Reported by JLF. Fixed on 20250419.                                        */
/* Uses parserOnly: x, y are uninitialized so Sign() would fail at runtime.  */
/******************************************************************************/

::Method test_bif_expression_arguments
  self~parserOnly("Say sign(x - y)")
  self~parserOnly("Say sign(x y)")

/******************************************************************************/
/* TRACE needs special handling because of the "?" prefix.                    */
/* Reported by JLF. Fixed on 20250419.                                        */
/* Uses parserOnly: "?a" activates interactive trace, which hangs.           */
/******************************************************************************/

::Method test_trace_question_prefix
  self~parserOnly('Call Trace "?a"')