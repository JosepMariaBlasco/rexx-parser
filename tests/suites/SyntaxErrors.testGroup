/******************************************************************************/
/* Error 99 — Miscellaneous second-pass and directive errors                   */
/******************************************************************************/

::Method test_error_99_duplicate_names
  self~parserError(99.901,  '::Class C; ::Class  C Public')
  self~parserError(99.901,  '::Class C; ::Class "c"')
  self~parserError(99.902,  "::Class C; ::Method M Class; ::Method M Class")
  self~parserError(99.902,  "::Class C; ::Method M; ::Method M ")
  self~parserError(99.902,  "::Method M; ::Method  M ")
  self~parserError(99.902,  '::Method M; ::Method "m"')
  self~parserError(99.903,  '::Routine repetitious; ::Routine repetitious')
  self~parserError(99.903,  '::Routine  repetitious; ::Routine "repetitious"')

::Method test_error_99_directives
  self~parserError(99.905,  "::Method M Class")
  self~parserError(99.906,  "::Constant c (1+2)")
  self~parserError(99.907,  '::Method M; Say "Hi"; Expose a b c')

  self~parserError(99.910,  '::Method M; Say "Hi"; Use Local x')

  self~parserError(99.916,  "::Potato")
  self~parserError(99.917,  '::Routine r external "library rxmath RxCalcSqrt xx"')

  self~parserError(99.925,  '::Attribute "test "')

  self~parserError(99.930,  "Use Arg a,...,b")
  self~parserError(99.931,  '::Class C; ::Method A Class; ::Attribute A Get Class; Return 1')
  self~parserError(99.931,  '::Attribute A Get; Return 1; ::Attribute A Get; Return 2')
  self~parserError(99.931,  '::Class C; ::Method A; ::Attribute A Get; Return 1')
  self~parserError(99.931,  '::Class C; ::Method "A=" Class; ::Attribute A Set Class; Return 1')
  self~parserError(99.931,  '::Attribute A Set; Return 1; ::Attribute A Set; Return 2')
  self~parserError(99.931,  '::Class C; ::Method "A="; ::Attribute A Set; Return 1')
  self~parserError(99.931,  '::Attribute  A; ::Attribute "a"')
  self~parserError(99.932,  '::Class Class; ::Method C Class; Say "Hi"; ::Constant C Two')
  self~parserError(99.932,  '::Constant C One; ::Constant C Two')
  self~parserError(99.932,  '::Class Class; ::Method C; Say "Hi"; ::Constant C Two')
  self~parserError(99.932,  '::Constant  C  12; ::Constant "c" 14')
  self~parserError(99.933,  '::Class C; ::Method M Abstract; Say "Hi!"')
  self~parserError(99.934,  '::Method M Attribute; Say "Hi!"')
  self~parserError(99.935,  '::Class C; ::attribute top set external "LIBRARY ooshapes rect_setTop"; Say "Hi!"')
  self~parserError(99.936,  '::Class C; ::Method Init External "LIBRARY rxregexp RegExp_Init"; Say "Hi!"')
  self~parserError(99.937,  '::Attribute A; Say "Hi!"')
  self~parserError(99.938,  '::Constant C;  Say "Hi!"')
  self~parserError(99.939, ('::Routine r external "LIBRARY rxmath RxCalcPi"', 'Say "Hi!"'))
  self~parserError(99.940, ('::Attribute a get abstract', 'Say "Hi!"'))

::Method test_error_99_resources
  self~parserError(99.942, ('::Resource r end pp', -
                       'x',                   -
                       'PP',                  -
                       '',                    -
                       '::Resource r',        -
                       'y',                   -
                       '::END'))
  self~parserError(99.942, ('::Resource r end pp', -
                       'x',                   -
                       'PP',                  -
                       '',                    -
                       '::Resource "r"',      -
                       'y',                   -
                       '::END'))
  self~parserError(99.943, ('::Resource r end pp','x'))
  self~parserError(99.944,  "::Requires R namespace rexx")

  self~parserError(99.946,  '::Method M Delegate z; Say "Hello"')
  self~parserError(99.947,  '::Attribute A get Delegate z; Say "Hello"')
  self~parserError(99.948,  "Use local a.2")
  self~parserError(99.950,  "Use Arg >a = 4")

/******************************************************************************/
/* Multi-line error tests (migrated from tests/errormessages/)                */
/******************************************************************************/

::Method test_multiline_error_47_003
  -- Label in ELSE clause (47.003.else.instruction.rexx)
  self~parserError(47.003, ("If 1", "Then", "Nop", "Else", "X: Nop"))
  -- Known divergence: interpreter says found "ELSE", parser says found "X".
  -- Same error code (47.003), but different label in the message.
  -- (47.003.else.clause.rexx)
  -- self~parserError(47.003, ("If 1", "Then", "Nop", "X: Else", "Nop"))
  -- Known divergence: parser gives 47.003, interpreter gives 18.001.
  -- The label "consumes" the THEN, so the interpreter sees a missing THEN.
  -- (47.003.then.clause.rexx)
  -- self~parserError(47.003, ("If 1", "X: Then", "Nop"))

::Method test_multiline_error_47_004
  -- Known divergence: parser gives 47.004, interpreter gives 18.002.
  -- Same issue as 47.003 then.clause: the label consumes the THEN.
  -- (47.004.then.clause.1.rexx)
  -- self~parserError(47.004, ("Select", "  When 1 ", "  X: Then Nop", "End"))
  -- (47.004.then.clause.n.rexx)
  -- self~parserError(47.004, ("Select", "  When 1 Then Nop", "  When 1 ", "  X: Then Nop", "End"))
  Nop

::Method test_multiline_error_99_913
