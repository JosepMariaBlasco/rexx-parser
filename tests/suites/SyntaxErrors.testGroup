  self~parserError(27.902,  "Do ubt = 1 To 2 To 3")
  self~parserError(27.902,  "Do with index i over me for 1 for 2")

  self~parserError(27.904,  "Do With Item A *")
  self~parserError(27.904,  "Do With Index I")

  self~parserError(27.905,  "Do label l counter c")
  self~parserError(27.905,  "Do counter c")

