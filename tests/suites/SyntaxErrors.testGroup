/*                                                                            */
/* Version history:                                                           */
/*                                                                            */
/* Date     Version Details                                                   */
/* -------- ------- --------------------------------------------------------- */
/* 20260316    0.5  Migrated from ParserChecks.test to ooRexxUnit             */
/*                                                                            */
/******************************************************************************/

parse source . . fileSpec
group = .TestGroup~new(fileSpec)
group~add(.SyntaxErrors.testGroup)
If group~isAutomatedTest Then
  Return group
Else
  Return group~suite~execute~~print

::Requires "ooTest.frm"
::Requires "ParserTestCase.cls"

::Class SyntaxErrors.testGroup Subclass ParserTestCase Public

/******************************************************************************/
/* Error 06 — Unmatched comment, unclosed string                              */
/******************************************************************************/

::Method test_error_06
  self~parserError(06.001, ("Say 'Hello!' /*/*        ", -
                       "*/i = i + 1              ", -
                       "                         ", -
                       "/* */                    "))
  self~parserError(06.002, ("Say 'Hello!              ", -
                       "i = i + 1                "))
  self~parserError(06.003, ('Say "Hello!              ', -
                       'Say i                    '))

/******************************************************************************/
/* Error 07 — SELECT errors                                                   */
/******************************************************************************/

::Method test_error_07
  self~parserError(07.001,  "Select; End              ")
  self~parserError(07.002,  "Select Case n; i = 1     ")
  self~parserError(07.002,  "Select       ; i = 1     ")

/******************************************************************************/
/* Error 08 — THEN/ELSE without IF                                            */
/******************************************************************************/

::Method test_error_08
  self~parserError(08.001,  "a = 2; Then Say n        ")
  self~parserError(08.002,  "a = 2; Else Say n        ")

/******************************************************************************/
/* Error 09 — WHEN/OTHERWISE without SELECT                                   */
/******************************************************************************/

::Method test_error_09
  self~parserError(09.001,  "a = 2; When 1 Then Say n ")
  self~parserError(09.002,  "a = 2; Otherwise   Say n ")

/******************************************************************************/
/* Error 10 — END errors                                                      */
/******************************************************************************/

::Method test_error_10
  self~parserError(10.001,  "a = 2; End               ")

  self~parserError(10.002,  "Do   Label k i = 1 To 3; Say 'Hi';   End j")
  self~parserError(10.002,  "Loop Label k i = 1 To 3; Say 'Hi';   End j")
  self~parserError(10.002,  "Do           i = 1 To 3; Say 'Hi';   End j")
  self~parserError(10.002,  "Loop         i = 1 To 3; Say 'Hi';   End j")
  -- Known parser bug: 10.003 message has swapped substitution parameters
  -- (parser says "line J ... found 1" instead of "line 1 ... found J").
  -- Parser detects the correct error code, but the message args are inverted.
  -- self~parserError(10.003,  "Do;   Say HI; End j")
  -- self~parserError(10.003,  "Loop; Say HI; End j")
  self~parserError(10.004,  "Select Label l; When 1 Then Say Nop; End j")

  -- Known parser bug: same swapped substitution parameters as 10.003
  -- self~parserError(10.007,  "Select; When 1 Then Say Nop; End j")

/******************************************************************************/
/* Error 13 — Invalid character                                               */
/******************************************************************************/

::Method test_error_13
  self~parserError(13.001,  "i = @")

/******************************************************************************/
/* Error 14 — Incomplete DO/SELECT/IF/LOOP                                    */
/******************************************************************************/

::Method test_error_14
  self~parserError(14.001,  "Do; Nop; i = 1                             ")
  self~parserError(14.002,  "Select; When 0 Then Say 1                  ")
  self~parserError(14.003,  "If a; Then                                 ")
  self~parserError(14.003,  "Select Case a; When 'A'; Then              ")
  self~parserError(14.004,  "If a Then Nop; Else                        ")
  self~parserError(14.005,  "Loop; Nop                                  ")
  self~parserError(14.901,  "Select; When 0 Then Nop; Otherwise Say Ugh ")

/******************************************************************************/
/* Error 15 — Invalid hex/binary string                                       */
/******************************************************************************/

::Method test_error_15
  self~parserError(15.001,  "x = 'FE 'X")
  self~parserError(15.001,  "x = ' FE'X")
  self~parserError(15.002,  "b = '11 'b")
  self~parserError(15.002,  "b = ' 11'b")
  self~parserError(15.003,  "X = '013BEFh88'x")
  self~parserError(15.004,  "B = '0120001'B")
  self~parserError(15.005,  "x = 'abc def'X")
  self~parserError(15.006,  "B = '11000 00011'B")

/******************************************************************************/
/* Error 18 — THEN/WHEN expected                                              */
/******************************************************************************/

::Method test_error_18
  self~parserError(18.001,  "If a = b; Say 2")
  self~parserError(18.002,  "Select; When 1; Nop")

/******************************************************************************/
/* Error 19 — Expected string or symbol                                       */
/******************************************************************************/

::Method test_error_19
  self~parserError(19.002,  "Call                    *")
  self~parserError(19.003,  "Call   On Error    Name *")
  self~parserError(19.003,  "Signal On Error    Name *")
  self~parserError(19.003,  "Call   On User pop Name *")
  self~parserError(19.003,  "Signal On User pop Name *")
  self~parserError(19.004,  "Signal")

  self~parserError(19.901,  "Say hi; ::Class")
  self~parserError(19.902,  "Say hi; ::Class C; ::Method")
  self~parserError(19.903,  "Say hi; ::Routine")
  self~parserError(19.904,  "Say hi; ::Requires")
  self~parserError(19.905,  "Say hi; ::Attribute a external")
  self~parserError(19.905,  "Say hi; ::Method M External")
  self~parserError(19.906,  "Say hi; ::Class C Metaclass")
  self~parserError(19.907,  "Say hi; ::Class C Subclass")
  self~parserError(19.908,  "Say hi; ::Class C Inherit")
  self~parserError(19.909,  "Say hi; Say a~")

  self~parserError(19.913,  "::Class C MixinClass")
  self~parserError(19.914,  "::Attribute *")
  self~parserError(19.915,  "::Constant *")
  self~parserError(19.916,  "::Constant C *")
  self~parserError(19.917,  "::Options digits *")
  self~parserError(19.918,  "::Options fuzz *")
  self~parserError(19.919,  "::Options trace *")
  self~parserError(19.920,  "::Resource *")
  self~parserError(19.921,  "::Resource R END *")

  self~parserError(19.923,  "::Annotate package kk *")
  self~parserError(19.924,  "::Annotate package kk")
  self~parserError(19.925,  "::Class C; ::Annotate class *")

